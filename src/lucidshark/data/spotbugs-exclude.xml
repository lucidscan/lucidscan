<?xml version="1.0" encoding="UTF-8"?>
<!--
  LucidShark Default SpotBugs Exclude Filter

  This filter excludes bug patterns that are commonly noisy or produce
  false positives in modern Java codebases. Users can override this by
  providing their own filter file in the project root.

  Custom filter locations checked (in order):
    - spotbugs-exclude.xml
    - spotbugs-filter.xml
    - .spotbugs/exclude.xml
    - config/spotbugs/exclude.xml

  SpotBugs documentation: https://spotbugs.readthedocs.io/en/stable/filter.html
-->
<FindBugsFilter>
    <!-- Serialization warnings - often false positives in modern frameworks -->
    <Match>
        <Bug pattern="SE_BAD_FIELD"/>
    </Match>
    <Match>
        <Bug pattern="SE_BAD_FIELD_STORE"/>
    </Match>
    <Match>
        <Bug pattern="SE_NO_SERIALVERSIONID"/>
    </Match>
    <Match>
        <Bug pattern="SE_TRANSIENT_FIELD_NOT_RESTORED"/>
    </Match>

    <!-- Internal representation exposure - too strict for most APIs -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!-- Mutable static fields - often intentional (caches, registries, etc.) -->
    <Match>
        <Bug pattern="MS_SHOULD_BE_FINAL"/>
    </Match>
    <Match>
        <Bug pattern="MS_PKGPROTECT"/>
    </Match>
    <Match>
        <Bug pattern="MS_MUTABLE_COLLECTION"/>
    </Match>
    <Match>
        <Bug pattern="MS_MUTABLE_COLLECTION_PKGPROTECT"/>
    </Match>

    <!-- Unread/unwritten fields - often used via reflection or dependency injection -->
    <Match>
        <Bug pattern="URF_UNREAD_FIELD"/>
    </Match>
    <Match>
        <Bug pattern="URF_UNREAD_PUBLIC_OR_PROTECTED_FIELD"/>
    </Match>
    <Match>
        <Bug pattern="UWF_UNWRITTEN_FIELD"/>
    </Match>
    <Match>
        <Bug pattern="UWF_UNWRITTEN_PUBLIC_OR_PROTECTED_FIELD"/>
    </Match>

    <!-- Dead local store - compiler optimizes these anyway -->
    <Match>
        <Bug pattern="DLS_DEAD_LOCAL_STORE"/>
    </Match>

    <!-- Inner class should be static - code style preference -->
    <Match>
        <Bug pattern="SIC_INNER_SHOULD_BE_STATIC"/>
    </Match>
    <Match>
        <Bug pattern="SIC_INNER_SHOULD_BE_STATIC_ANON"/>
    </Match>
    <Match>
        <Bug pattern="SIC_INNER_SHOULD_BE_STATIC_NEEDS_THIS"/>
    </Match>

    <!-- Write to static from instance - often intentional pattern -->
    <Match>
        <Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD"/>
    </Match>

    <!-- Exclude test classes from certain checks -->
    <Match>
        <Class name="~.*Test(s)?$"/>
        <Bug pattern="RV_RETURN_VALUE_IGNORED_NO_SIDE_EFFECT"/>
    </Match>
    <Match>
        <Class name="~.*Test(s)?$"/>
        <Bug pattern="NP_NONNULL_PARAM_VIOLATION"/>
    </Match>

    <!-- Exclude generated code (common patterns) -->
    <Match>
        <Class name="~.*\$\$.*"/>
    </Match>
    <Match>
        <Class name="~.*_Generated$"/>
    </Match>
    <Match>
        <Package name="~.*\.generated\..*"/>
    </Match>
</FindBugsFilter>
